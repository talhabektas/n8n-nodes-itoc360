{
  "name": "@itservtechnology/n8n-nodes-itoc360",
  "version": "0.1.0",
  "description": "n8n community node to send alerts to itoc360 alert routing and on-call management",
  "license": "MIT",
  "homepage": "https://itoc360.com",
  "keywords": ["n8n-community-node-package"],
  "author": {
    "name": "Mehmet Talha Bektaş",
    "email": "talha.bektas@itserv.com.tr"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/talhabektas/n8n-nodes-itoc360.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": ["dist/credentials/Itoc360Api.credentials.js"],
    "nodes": ["dist/nodes/Itoc360/Itoc360.node.js"]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": { "n8n-workflow": "*" }
}